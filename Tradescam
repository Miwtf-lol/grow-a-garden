-- Toggle Creator
local function CreateScamToggle(Text, Callback)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Parent = ContentFrame
    ToggleFrame.BackgroundColor3 = Color3.fromRGB(255, 192, 203)
    ToggleFrame.Size = UDim2.new(1, 0, 0, 65)
    ToggleFrame.Position = UDim2.new(0, 0, 0, (#ContentFrame:GetChildren() - 1) * 70)
    ToggleFrame.BorderSizePixel = 0
    
    local TCorner = Instance.new("UICorner")
    TCorner.CornerRadius = UDim.new(0, 12)
    TCorner.Parent = ToggleFrame
    
    local TLabel = Instance.new("TextLabel")
    TLabel.Parent = ToggleFrame
    TLabel.BackgroundTransparency = 1
    TLabel.Size = UDim2.new(0.7, 0, 1, 0)
    TLabel.Position = UDim2.new(0, 15, 0, 0)
    TLabel.Font = Enum.Font.GothamSemibold
    TLabel.Text = "💥 " .. Text .. " 💥"
    TLabel.TextColor3 = Color3.new(0.1, 0, 0.3)
    TLabel.TextScaled = true
    TLabel.TextXAlignment = Enum.TextXAlignment.Left
    
    local ToggleBtn = Instance.new("TextButton")
    ToggleBtn.Parent = ToggleFrame
    ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 180)
    ToggleBtn.Size = UDim2.new(0, 90, 0, 45)
    ToggleBtn.Position = UDim2.new(1, -105, 0, 10)
    ToggleBtn.Text = "OFF"
    ToggleBtn.TextColor3 = Color3.new(1,1,1)
    ToggleBtn.TextScaled = true
    ToggleBtn.Font = Enum.Font.GothamBold
    
    local BtnCorner = Instance.new("UICorner")
    BtnCorner.CornerRadius = UDim.new(0, 22)
    BtnCorner.Parent = ToggleBtn
    
    local Enabled = false
    ToggleBtn.MouseButton1Click:Connect(function()
        Enabled = not Enabled
        getgenv().TradeScamConfig[Text:gsub(" ", "")] = Enabled
        
        if Enabled then
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(50, 205, 50)
            ToggleBtn.Text = "ON"
            Callback(true)
            StatusLabel.Text = "💖 " .. Text .. " ACTIVATED! 💖"
        else
            ToggleBtn.BackgroundColor3 = Color3.fromRGB(255, 150, 180)
            ToggleBtn.Text = "OFF"
            Callback(false)
            StatusLabel.Text = "💖 READY - WAITING FOR TRADES 💖"
        end
    end)
end

-- Create Toggles
CreateScamToggle("Auto Accept Trade", function(state)
    if state then
        -- Hook trade GUI
        local mt = getrawmetatable(game)
        local old = mt.__namecall
        setreadonly(mt, false)
        mt.__namecall = newcclosure(function(self, ...)
            local args = {...}
            local method = getnamecallmethod()
            
            if method == "FireServer" and tostring(self):find("Trade") and getVMwtfConfig().AutoAccept then
                if args[1] == "Accept" or args[1] == "Confirm" then
                    StatusLabel.Text = "💖 AUTO-ACCEPT FIRED! SCAM SUCCESS! 💖"
                    return old(self, ...)
                end
            end
            return old(self, ...)
        end)
        setreadonly(mt, true)
    end
end)

CreateScamToggle("Freeze Target", function(state)
    spawn(function()
        while getVMwtfConfig().FreezeTarget do
            for _, plr in pairs(Players:GetPlayers()) do
                if plr ~= player and plr.Character then
                    -- Freeze player
                    if plr.Character:FindFirstChild("Humanoid") then
                        plr.Character.Humanoid.PlatformStand = true
                    end
                    -- Disable controls
                    if plr.PlayerGui:FindFirstChild("PlayerGui") then
                        for _, gui in pairs(plr.PlayerGui.PlayerGui:GetDescendants()) do
                            if gui:IsA("TextButton") or gui:IsA("ImageButton") then
                                gui.Active = false
                            end
                        end
                    end
                end
            end
            task.wait(0.1)
        end
    end)
end)

CreateScamToggle("Full Scam Mode", function(state)
    if state then
        getVMwtfConfig().AutoAccept = true
        getVMwtfConfig().FreezeTarget = true
        StatusLabel.Text = "💖 FULL SCAM MODE ACTIVATED! 💖"
        -- Trigger all at once
        if TradeRemotes.Accept then TradeRemotes.Accept:FireServer("Accept") end
        if TradeRemotes.Freeze then TradeRemotes.Freeze:FireServer("AllPlayers") end
    else
        getVMwtfConfig().AutoAccept = false
        getVMwtfConfig().FreezeTarget = false
    end
end)

