-- Find Trading Remotes
local TradeRemotes = {}
for _, obj in pairs(ReplicatedStorage:GetDescendants()) do
    if obj:IsA("RemoteEvent") then
        local name = obj.Name:lower()
        if name:find("trade") or name:find("accept") or name:find("confirm") then
            TradeRemotes.Accept = obj
        elseif name:find("decline") or name:find("cancel") then
            TradeRemotes.Decline = obj
        elseif name:find("freeze") or name:find("lock") then
            TradeRemotes.Freeze = obj
        end
    end
end

