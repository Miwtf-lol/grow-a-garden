local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local LP = Players.LocalPlayer

local Config = {
    Enabled = true,
    ShowDistance = true,
    ShowHealth = true,
    TeamCheck = false,
    Color = Color3.fromRGB(255, 60, 60)
}

local ESPObjects = {}

local function createESP(player)
    if player == LP then return end

    local function attach(char)
        if ESPObjects[player] then
            ESPObjects[player]:Destroy()
        end

        -- Highlight
        local highlight = Instance.new("Highlight")
        highlight.Name = "DEV_ULTRA_ESP"
        highlight.Parent = char
        ESPObjects[player] = highlight

        -- Billboard
        local head = char:WaitForChild("Head", 5)
        if not head then return end

        local billboard = Instance.new("BillboardGui")
        billboard.Size = UDim2.new(0, 220, 0, 60)
        billboard.AlwaysOnTop = true
        billboard.StudsOffset = Vector3.new(0, 2.5, 0)
        billboard.Parent = head

        local text = Instance.new("TextLabel")
        text.Size = UDim2.new(1,0,1,0)
        text.BackgroundTransparency = 1
        text.TextColor3 = Color3.new(1,1,1)
        text.TextStrokeTransparency = 0
        text.TextScaled = true
        text.Font = Enum.Font.GothamBold
        text.Parent = billboard

        RunService.RenderStepped:Connect(function()
            if not char or not char.Parent then return end

            highlight.Enabled = Config.Enabled
            billboard.Enabled = Config.Enabled

            if Config.TeamCheck and player.Team == LP.Team then
                highlight.Enabled = false
                billboard.Enabled = false
                return
            end

            highlight.FillColor = Config.Color

            local hrp = char:FindFirstChild("HumanoidRootPart")
            local hum = char:FindFirstChildOfClass("Humanoid")
            local my = LP.Character and LP.Character:FindFirstChild("HumanoidRootPart")

            local info = player.Name

            if Config.ShowDistance and hrp and my then
                local dist = math.floor((hrp.Position - my.Position).Magnitude)
                info = info .. " | " .. dist .. "m"
            end

            if Config.ShowHealth and hum then
                info = info .. " | HP: " .. math.floor(hum.Health)
            end

            text.Text = info
        end)
    end

    if player.Character then attach(player.Character) end
    player.CharacterAdded:Connect(attach)
end

for _,p in pairs(Players:GetPlayers()) do
    createESP(p)
end

Players.PlayerAdded:Connect(createESP)
