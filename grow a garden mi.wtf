-- PERFECT TOGGLE SYSTEM
local ToggleY = 0
local function createToggle(name, callback, icon)
    local ToggleFrame = Instance.new("Frame")
    ToggleFrame.Size = UDim2.new(1, 0, 0, 45)
    ToggleFrame.Position = UDim2.new(0, 0, 0, ToggleY)
    ToggleFrame.BackgroundTransparency = 1
    ToggleFrame.Parent = ScrollFrame
    
    local IconLabel = Instance.new("TextLabel")
    IconLabel.Size = UDim2.new(0, 35, 1, 0)
    IconLabel.BackgroundTransparency = 1
    IconLabel.Text = icon
    IconLabel.TextColor3 = Color3.fromRGB(150, 255, 150)
    IconLabel.TextSize = 20
    IconLabel.Font = Enum.Font.GothamBold
    IconLabel.Parent = ToggleFrame
    
    local NameLabel = Instance.new("TextLabel")
    NameLabel.Size = UDim2.new(0.55, 0, 1, 0)
    NameLabel.Position = UDim2.new(0, 40, 0, 0)
    NameLabel.BackgroundTransparency = 1
    NameLabel.Text = name
    NameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
    NameLabel.TextSize = 16
    NameLabel.Font = Enum.Font.GothamSemibold
    NameLabel.Parent = ToggleFrame
    
    local SwitchBg = Instance.new("Frame")
    SwitchBg.Size = UDim2.new(0, 55, 0, 32)
    SwitchBg.Position = UDim2.new(1, -65, 0.5, -16)
    SwitchBg.BackgroundColor3 = Color3.fromRGB(60, 60, 90)
    SwitchBg.Parent = ToggleFrame
    
    local SwitchCorner = Instance.new("UICorner")
    SwitchCorner.CornerRadius = UDim.new(0, 16)
    SwitchCorner.Parent = SwitchBg
    
    local SwitchKnob = Instance.new("Frame")
    SwitchKnob.Size = UDim2.new(0, 28, 0, 28)
    SwitchKnob.Position = UDim2.new(0, 2, 0, 2)
    SwitchKnob.BackgroundColor3 = Color3.fromRGB(255, 90, 90)
    SwitchKnob.Parent = SwitchBg
    
    local KnobCorner = Instance.new("UICorner")
    KnobCorner.CornerRadius = UDim.new(0, 14)
    KnobCorner.Parent = SwitchKnob
    
    local ToggleClick = Instance.new("TextButton")
    ToggleClick.Size = UDim2.new(1, 0, 1, 0)
    ToggleClick.BackgroundTransparency = 1
    ToggleClick.Text = ""
    ToggleClick.Parent = SwitchBg
    
    local toggled = false
    ToggleClick.MouseButton1Click:Connect(function()
        toggled = not toggled
        local knobPos = toggled and UDim2.new(1, -30, 0, 2) or UDim2.new(0, 2, 0, 2)
        local knobColor = toggled and Color3.fromRGB(90, 255, 90) or Color3.fromRGB(255, 90, 90)
        
        TweenService:Create(SwitchKnob, TweenInfo.new(0.25), {
            Position = knobPos,
            BackgroundColor3 = knobColor
        }):Play()
        
        callback(toggled)
    end)
    
    ToggleY = ToggleY + 55
    ScrollFrame.CanvasSize = UDim2.new(0, 0, 0, ToggleY + 20)
end

-- CREATE ALL TOGGLES
createToggle("Auto Farm", function(state) Config.AutoFarm = state end, "🌱")
