-- Mini toggles (compact)
local MiniY = 45
local function miniToggle(name, callback)
    local mToggle = Instance.new("TextButton")
    mToggle.Size = UDim2.new(1, -20, 0, 30)
    mToggle.Position = UDim2.new(0, 10, 0, MiniY)
    mToggle.BackgroundColor3 = Color3.fromRGB(50, 50, 80)
    mToggle.Text = name .. ": OFF"
    mToggle.TextColor3 = Color3.fromRGB(255, 255, 255)
    mToggle.Font = Enum.Font.Gotham
    mToggle.Parent = MiniUI
    
    local mCorner = Instance.new("UICorner")
    mCorner.CornerRadius = UDim.new(0, 6)
    mCorner.Parent = mToggle
    
    local mEnabled = false
    mToggle.MouseButton1Click:Connect(function()
        mEnabled = not mEnabled
        mToggle.Text = name .. ": " .. (mEnabled and "ON" or "OFF")
        mToggle.BackgroundColor3 = mEnabled and Color3.fromRGB(0, 180, 0) or Color3.fromRGB(180, 0, 0)
        callback(mEnabled)
    end)
    
    MiniY = MiniY + 40
end

miniToggle("Quick Farm", function(state) Config.AutoFarm = state end)
miniToggle("Eggs Only", function(state) Config.EggAura = state end)
miniToggle("Pet Spam", function(state) Config.PetSpam = state end)

-- EVENT HANDLERS
MiniToggle.MouseButton1Click:Connect(function()
    Config.ShowMiniUI = not Config.ShowMiniUI
    MiniUI.Visible = Config.ShowMiniUI
    MiniToggle.Text = "Mini UI: " .. (Config.ShowMiniUI and "ON" or "OFF")
    MiniToggle.BackgroundColor3 = Config.ShowMiniUI and Color3.fromRGB(0, 200, 0) or Color3.fromRGB(200, 0, 0)
end)

