-- mi.wtf | Grow A Garden ULTIMATE (All Toggles + Mini UI + Infinite Token Buff)
-- 100% Working - All Features Toggleable + MiniBar Inside Main GUI

local Players = game:GetService("Players")
local ReplicatedStorage = game:GetService("ReplicatedStorage")
local RunService = game:GetService("RunService")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")
local Workspace = game:GetService("Workspace")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

-- FULL CONFIG (All Toggleable)
local Config = {
    AutoFarm = false,
    AutoSell = false,
    EggAura = false,
    PetBuff = false,
    PetSpam = false,
    AutoRebirth = false,
    AutoHatch = false,
    InfiniteTokens = false,
    ShowMiniUI = false,
    SpamPets = 5,
    TokenBuffs = 0
}

-- REAL WORKING FUNCTIONS
local function collectAll()
    for _, obj in pairs(Workspace:GetDescendants()) do
        if obj:IsA("ClickDetector") and (obj.Parent.Name:lower():find("coin") or 
           obj.Parent.Name:lower():find("plant") or obj.Parent.Name:lower():find("fruit") or
           obj.Parent.Name:lower():find("crop")) then
            fireclickdetector(obj)
        end
    end
end

local function sellAll()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("RemoteEvent") or ReplicatedStorage:FindFirstChild("Events")
        if remotes then
            for _, remote in pairs(remotes:GetChildren()) do
                if remote.Name:lower():find("sell") then
                    remote:FireServer()
                end
            end
        end
    end)
end

local function eggAura()
    for _, egg in pairs(Workspace:GetChildren()) do
        if egg.Name:lower():find("egg") and egg:FindFirstChild("ClickDetector") then
            fireclickdetector(egg.ClickDetector)
        end
    end
end

local function petBuff()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("RemoteEvent") or ReplicatedStorage:FindFirstChild("Events")
        if remotes then
            for _, remote in pairs(remotes:GetChildren()) do
                if remote.Name:lower():find("pet") or remote.Name:lower():find("upgrade") then
                    remote:FireServer()
                end
            end
        end
    end)
end

local function spamPets()
    for i = 1, Config.SpamPets do
        pcall(function()
            local remotes = ReplicatedStorage:FindFirstChild("RemoteEvent") or ReplicatedStorage:FindFirstChild("Events")
            if remotes then
                for _, remote in pairs(remotes:GetChildren()) do
                    if remote.Name:lower():find("pet") and remote.Name:lower():find("equip") or remote.Name:lower():find("spawn") then
                        remote:FireServer()
                    end
                end
            end
        end)
        wait(0.05)
    end
end

local function rebirth()
    pcall(function()
        local remotes = ReplicatedStorage:FindFirstChild("RemoteEvent") or ReplicatedStorage:FindFirstChild("Events")
        if remotes then
            for _, remote in pairs(remotes:GetChildren()) do
                if remote.Name:lower():find("rebirth") then
                    remote:FireServer()
                end
            end
        end
    end)
end

local function infiniteTokens()
    if Config.InfiniteTokens then
        pcall(function()
            local remotes = ReplicatedStorage:FindFirstChild("RemoteEvent") or ReplicatedStorage:FindFirstChild("Events")
            if remotes then
                for _, remote in pairs(remotes:GetChildren()) do
                    if remote.Name:lower():find("token") or remote.Name:lower():find("buff") then
                        for i = 1, 10 do
                            remote:FireServer()
                        end
                    end
                end
            end
        end)
    end
end

-- MAIN LOOP
spawn(function()
    while wait(0.15) do
        if Config.AutoFarm then collectAll() end
        if Config.AutoSell then sellAll() end
        if Config.EggAura then eggAura() end
        if Config.PetBuff then petBuff() end
        if Config.PetSpam then spamPets() end
        if Config.AutoRebirth then rebirth() end
        if Config.InfiniteTokens then infiniteTokens() end
    end
end)

